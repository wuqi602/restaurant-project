page { background: #f5f5f5; }

.notice-page {
  display: flex; flex-direction: column; height: 100vh;
}

/* ===== 头部 ===== */
.notice-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 30rpx; background: #fff; flex-shrink: 0;
}
.header-left { display: flex; align-items: baseline; gap: 16rpx; }
.notice-title { font-size: 40rpx; font-weight: bold; color: #222; }
.notice-subtitle { font-size: 24rpx; color: #EE3E0E; }
.read-all-btn {
  font-size: 26rpx; color: #EE3E0E; background: rgba(238,62,14,0.08);
  border: none; border-radius: 30rpx; padding: 8rpx 24rpx; line-height: 1.8;
}
.read-all-btn.disabled { color: #ccc; background: #f5f5f5; }

/* ===== 分类标签 ===== */
.tab-bar {
  display: flex; white-space: nowrap; background: #fff;
  padding: 0 20rpx 20rpx; flex-shrink: 0; gap: 16rpx;
}
.tab-item {
  display: inline-flex; padding: 10rpx 28rpx; font-size: 26rpx;
  color: #666; border-radius: 30rpx; background: #f5f5f5;
}
.tab-item.active { color: #fff; background: #EE3E0E; font-weight: bold; }

/* ===== 列表 ===== */
.notice-list { flex: 1; padding: 20rpx 24rpx; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; padding-top: 200rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #999; }

/* 通知卡片 */
.notice-card {
  display: flex; background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.notice-card.read { opacity: 0.7; }
.notice-card.expanded { box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }

/* 左侧图标 */
.card-icon {
  width: 72rpx; height: 72rpx; border-radius: 50%; display: flex;
  align-items: center; justify-content: center; font-size: 36rpx;
  flex-shrink: 0; margin-right: 20rpx;
}
.card-icon.promotion { background: #fff3e0; }
.card-icon.order { background: #e8f5e9; }
.card-icon.system { background: #e3f2fd; }
.card-icon.announce { background: #fce4ec; }

/* 中间内容 */
.card-body { flex: 1; min-width: 0; }
.card-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.card-tag {
  font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx;
  background: #f0f0f0; color: #666; flex-shrink: 0;
}
.card-tag.promotion { background: #fff3e0; color: #e65100; }
.card-tag.order { background: #e8f5e9; color: #2e7d32; }
.card-tag.system { background: #e3f2fd; color: #1565c0; }
.card-tag.announce { background: #fce4ec; color: #c62828; }
.card-date { font-size: 22rpx; color: #bbb; }
.unread-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%; background: #EE3E0E;
  margin-left: auto; flex-shrink: 0;
}
.card-title {
  font-size: 30rpx; font-weight: bold; color: #222;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
  overflow: hidden; margin-bottom: 4rpx;
}
.card-desc {
  font-size: 26rpx; color: #999;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-detail {
  margin-top: 12rpx; padding: 16rpx; background: #f9f9f9;
  border-radius: 12rpx; font-size: 26rpx; color: #555; line-height: 1.6;
}
