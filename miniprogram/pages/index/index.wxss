/* pages/index/index.wxss */

/* 容器占满全屏，并设为相对定位 */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景图：绝对定位铺满，不干扰按钮布局 */
.bg-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 按钮容器：绝对定位，位于底部偏上，水平居中 */
.overlay {
  position: absolute;
  bottom: 20%;          /* 距离底部20%处，可调整 */
  left: 0;
  width: 100%;
  z-index: 2;           /* 确保在背景图之上 */
  display: flex;
  justify-content: center;
  pointer-events: none; /* 让点击事件穿透，但按钮本身可点击（下面单独设置） */
}

/* 按钮样式：毛玻璃效果 + 品牌色 */
.enter-btn {
  pointer-events: auto; /* 恢复点击 */
  background: rgba(255, 255, 255, 0.85);
  color: #EE3E0E;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 60rpx;
  padding: 24rpx 100rpx;
  font-size: 38rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(12rpx);        /* 毛玻璃模糊效果 */
  -webkit-backdrop-filter: blur(12rpx); /* 兼容iOS */
  transition: all 0.3s ease;
}

/* 按钮点击效果 */
.enter-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}