<view class="page-order">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="status"
      class="tab {{currentTab === item.status ? 'active' : ''}}"
      data-status="{{item.status}}" bindtap="switchTab">
      {{item.name}}
    </view>
  </view>

  <scroll-view class="order-list" scroll-y>
    <view wx:if="{{orders.length === 0}}" class="empty">
      <text>暂无订单</text>
    </view>

    <view wx:for="{{orders}}" wx:key="id" class="order-card" bindtap="onOrderTap" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-id">#{{item.id}}</text>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>
      <view wx:for="{{item.items}}" wx:for-item="oi" wx:key="id" class="item-row">
        <image wx:if="{{oi.image}}" class="item-img" src="{{oi.image}}" mode="aspectFill"></image>
        <view wx:else class="item-img item-img-placeholder">🍔</view>
        <view class="item-info">
          <view class="item-name">{{oi.name}}</view>
          <view class="item-price">¥{{oi.price}}</view>
        </view>
        <text class="item-qty">×{{oi.quantity}}</text>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <text class="order-total">合计：<text class="price">¥{{item.finalPrice}}</text></text>
      </view>
    </view>
  </scroll-view>
</view>
