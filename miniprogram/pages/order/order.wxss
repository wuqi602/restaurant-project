.page-order { background: #f5f5f5; min-height: 100vh; }

.tabs { display: flex; background: #fff; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; position: sticky; top: 0; z-index: 9; }
.tab { flex: 1; text-align: center; font-size: 26rpx; color: #666; padding: 8rpx 0; position: relative; }
.tab.active { color: #EE3E0E; font-weight: bold; }
.tab.active::after { content: ''; position: absolute; bottom: -20rpx; left: 50%; transform: translateX(-50%); width: 40rpx; height: 4rpx; background: #EE3E0E; border-radius: 2rpx; }

.order-list { padding: 20rpx; }
.empty { display: flex; align-items: center; justify-content: center; height: 50vh; color: #999; font-size: 28rpx; }

.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.order-id { font-size: 24rpx; color: #999; }
.order-status { font-size: 26rpx; font-weight: bold; }
.order-status.pending { color: #EE3E0E; }
.order-status.paid { color: #43e97b; }
.order-status.completed { color: #667eea; }
.order-status.cancelled { color: #999; }

.item-row { display: flex; align-items: center; padding: 10rpx 0; }
.item-img { width: 72rpx; height: 72rpx; border-radius: 8rpx; background: #eee; margin-right: 16rpx; }
.item-img-placeholder { display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #ccc; }
.item-info { flex: 1; }
.item-name { font-size: 26rpx; color: #333; }
.item-price { font-size: 22rpx; color: #FF4D2E; }
.item-qty { font-size: 24rpx; color: #999; }

.order-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.order-time { font-size: 22rpx; color: #999; }
.order-total { font-size: 24rpx; color: #333; }
.price { color: #EE3E0E; font-size: 28rpx; font-weight: bold; }
