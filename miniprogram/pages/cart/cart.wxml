<!-- pages/cart/cart.wxml -->
<view class="cart-container">

<!-- 顶部导航 -->
<view class="cart-header">
  <view class="back-btn" bindtap="onBack">‹</view>
  <view class="title">购物车</view>
  <view class="clear-btn" bindtap="onClearCart" wx:if="{{cartList.length > 0}}">清空</view>
</view>

<!-- 购物车列表 -->
<scroll-view class="cart-list" scroll-y>
  <!-- 空状态 -->
  <view wx:if="{{cartList.length === 0}}" class="empty-cart">
    <view class="empty-icon">🛒</view>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去点餐吧～</text>
  </view>

  <!-- 有商品时渲染 -->
  <view wx:for="{{cartList}}" wx:key="id" class="cart-item">
    <!-- 商品信息 -->
    <view class="item-info">
      <image wx:if="{{item.image}}" class="item-image" src="{{item.image}}" mode="aspectFill"></image>
      <view wx:else class="item-image item-image-placeholder">🍔</view>
      <view class="item-detail">
        <view class="item-name">{{item.name}}</view>
        <view class="item-price">¥{{item.price}}</view>
      </view>
    </view>
    <!-- 数量操作 -->
    <view class="item-actions">
      <view class="qty-btn minus" bindtap="onDecrease" data-id="{{item.id}}">−</view>
      <view class="qty-num">{{item.quantity}}</view>
      <view class="qty-btn plus" bindtap="onIncrease" data-id="{{item.id}}">+</view>
      <view class="delete-btn" bindtap="onRemoveItem" data-id="{{item.id}}">✕</view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view style="height: 120rpx;"></view>
</scroll-view>

<!-- 底部结算栏 -->
<view class="cart-footer" wx:if="{{cartList.length > 0}}">
  <view class="total-info">
    <text class="total-label">合计：</text>
    <text class="total-price">¥{{totalPrice}}</text>
  </view>
  <view class="checkout-btn" bindtap="onCheckout">去结算 ({{totalCount}})</view>
</view>

</view>