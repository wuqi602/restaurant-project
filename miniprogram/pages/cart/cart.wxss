/* pages/cart/cart.wxss */
page {
  background-color: #f8f8f8;
}

.cart-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ===== 顶部导航 ===== */
.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.back-btn {
  font-size: 48rpx;
  color: #333;
  padding: 10rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
}
.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}

/* ===== 购物车列表 ===== */
.cart-list {
  flex: 1;
  padding: 20rpx;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}
.empty-hint {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 商品卡片 */
.cart-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.item-info {
  display: flex;
  align-items: center;
  flex: 1;
}
.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #eee;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.item-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ccc;
}
.item-detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
}
.item-price {
  font-size: 28rpx;
  color: #FF4D2E;
  margin-top: 8rpx;
}

/* 数量操作 */
.item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.qty-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
}
.qty-btn.minus {
  background: #f0f0f0;
  color: #333;
}
.qty-btn.plus {
  background: #EE3E0E;
  color: #fff;
}
.qty-num {
  min-width: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
}
.delete-btn {
  margin-left: 10rpx;
  padding: 8rpx;
  font-size: 30rpx;
  color: #ccc;
}

/* ===== 底部结算栏 ===== */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}
.total-info {
  display: flex;
  align-items: baseline;
}
.total-label {
  font-size: 28rpx;
  color: #333;
}
.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #EE3E0E;
}
.checkout-btn {
  background: #EE3E0E;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(238, 62, 14, 0.35);
}
.checkout-btn:active {
  opacity: 0.8;
}