.top-nav {
  background: linear-gradient(135deg, #FF6A00, #EE3E0E);
  padding: 20rpx 30rpx 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 999;
}
.shop-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}
.shop-name {
  font-size: 38rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
}
.shop-name .tag {
  background: rgba(255,255,255,0.3);
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 15rpx;
  font-weight: normal;
}
.announcement {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
}
.announcement .icon {
  margin-right: 8rpx;
}
.icon-search {
  width: 50rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
}

/* ===== 2. 主体布局（左分类 + 右列表） ===== */
.main-body {
  display: flex;
  height: calc(100vh - 110rpx); /* 减去顶部导航高度 */
  background: #f5f5f5;
}

/* ----- 左侧分类导航（宽度固定） ----- */
.left-category {
  width: 180rpx;
  background: #ffffff;
  height: 100%;
  box-sizing: border-box;
}
.left-category .cat-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #555;
  border-bottom: 1rpx solid #f5f5f5;
  border-left: 6rpx solid transparent;
  transition: all 0.15s;
  padding: 0 12rpx;
  text-align: center;
  line-height: 1.3;
  word-break: break-all;
}
.left-category .cat-item:active {
  background: #fafafa;
}
.left-category .cat-item.active {
  color: #EE3E0E;
  background: #fff6f3;
  border-left-color: #EE3E0E;
  font-weight: bold;
}

/* ----- 右侧菜品列表 ----- */
.right-menu {
  flex: 1;
  height: 100%;
  padding: 20rpx 20rpx 0 20rpx;
  box-sizing: border-box;
}

/* 分类标题（右侧列表中的分组标题） */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  padding: 10rpx 0 10rpx 20rpx;
  background: #f5f5f5;
}

/* 菜品卡片 */
.food-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  align-items: center;
}
.food-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #eee;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 48rpx;
}
.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140rpx;
}
.food-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
}
.food-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.food-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}
.food-price {
  color: #FF4D2E;
  font-size: 34rpx;
  font-weight: bold;
}
.food-price small {
  font-size: 24rpx;
}
.btn-add {
  width: 50rpx;
  height: 50rpx;
  background: #EE3E0E;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: lighter;
  box-shadow: 0 4rpx 10rpx rgba(238, 62, 14, 0.35);
}