<!--pages/menu/menu.wxml-->
<!-- pages/menu/menu.wxml -->



<!-- 顶部导航栏 -->
<view class="top-nav">
  <view class="shop-info">
    <view class="shop-name">
      好又来西餐厅
      <text class="tag">外卖</text>
    </view>
    <view class="announcement">
      <text class="icon">📢</text> 满30减10，满20减5，新用户无门槛立减10元！
    </view>
  </view>
  <view class="icon-search">🔍</view>
</view>

<!-- AI 智能推荐（横向滚动） -->
<view class="ai-recommend" wx:if="{{recommends.length > 0}}">
  <view class="ai-header">
    <text class="ai-title">🤖 AI 智能推荐</text>
    <text class="ai-badge">基于历史订单分析</text>
  </view>
  <scroll-view class="ai-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view wx:for="{{recommends}}" wx:key="id" class="ai-card" bindtap="onCardTap" data-id="{{item.id}}">
      <image wx:if="{{item.image}}" class="ai-img" src="{{item.image}}" mode="aspectFill"></image>
      <view wx:else class="ai-img ai-img-placeholder">🍔</view>
      <view class="ai-body">
        <text class="ai-name">{{item.name}}</text>
        <text class="ai-price">¥{{item.price}}</text>
        <text class="ai-reason">{{item.recommendReason}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 主体：左分类 + 右列表 -->
<view class="main-body">
  
  <!-- 左侧分类滚动区 -->
  <scroll-view class="left-category" scroll-y scroll-into-view="{{leftToView}}" enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      id="cat-item-{{index}}"
      class="cat-item {{currentCategoryIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onCategoryTap"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 右侧菜品滚动区 -->
  <scroll-view class="right-menu" scroll-y scroll-into-view="{{rightToView}}" bindscroll="onRightScroll">
    <view wx:if="{{menuList.length === 0}}" class="empty-state">
      <text>🍽️ 菜单正在准备中，请稍后再来~</text>
    </view>
    <view wx:for="{{menuList}}" wx:for-index="catIdx" wx:key="*this" id="cat-{{catIdx}}">
      <view class="section-title">{{categories[catIdx].name}}</view>
      <view wx:for="{{item}}" wx:for-index="foodIdx" wx:key="id">
        <view class="food-card" bindtap="onCardTap" data-id="{{item.id}}">
          <view class="food-img">
            <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" style="width:100%;height:100%;border-radius:12rpx;"></image>
            <text wx:else>🍔</text>
          </view>
          <view class="food-info">
            <view>
              <view class="food-name">{{item.name}}</view>
              <view class="food-desc">{{item.description}}</view>
            </view>
            <view class="food-bottom">
              <view class="food-price">¥{{item.price}}</view>
              <view class="btn-add" bindtap="onCardTap" data-id="{{item.id}}" data-x="add">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view style="height: 60rpx;"></view>
  </scroll-view>
  
</view>