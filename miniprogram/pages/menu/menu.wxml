<!--pages/menu/menu.wxml-->
<!-- pages/menu/menu.wxml -->



<!-- 顶部导航栏 -->
<view class="top-nav">
  <view class="shop-info">
    <view class="shop-name">
      好又来西餐厅
      <text class="tag">外卖</text>
    </view>
    <view class="announcement">
      <text class="icon">📢</text> 满30减10，满20减5，新用户无门槛立减10元！
    </view>
  </view>
  <view class="icon-search">🔍</view>
</view>

<!-- 主体：左分类 + 右列表 -->
<view class="main-body">
  
  <!-- 左侧分类滚动区 -->
  <scroll-view class="left-category" scroll-y scroll-into-view="{{leftToView}}" enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      id="cat-item-{{index}}"
      class="cat-item {{currentCategoryIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onCategoryTap"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 右侧菜品滚动区 -->
  <scroll-view class="right-menu" scroll-y scroll-into-view="{{rightToView}}" bindscroll="onRightScroll">
    <view wx:if="{{menuList.length === 0}}" class="empty-state">
      <text>🍽️ 菜单正在准备中，请稍后再来~</text>
    </view>
    <view wx:for="{{menuList}}" wx:for-item="category" wx:for-index="catIdx" wx:key="*this" id="cat-{{catIdx}}">
      <view class="section-title">{{categories[catIdx].name}}</view>
      <view wx:for="{{category}}" wx:for-item="food" wx:key="id">
        <view class="food-card" bindtap="onFoodTap" data-item="{{food}}">
          <view class="food-img">
            <image wx:if="{{food.image}}" src="{{food.image}}" mode="aspectFill" style="width:100%;height:100%;border-radius:12rpx;"></image>
            <text wx:else>🍔</text>
          </view>
          <view class="food-info">
            <view>
              <view class="food-name">{{food.name}}</view>
              <view class="food-desc">{{food.description}}</view>
            </view>
            <view class="food-bottom">
              <view class="food-price">¥{{food.price}}</view>
              <view class="btn-add" catch:tap="onAddToCart" data-item="{{food}}">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view style="height: 60rpx;"></view>
  </scroll-view>
  
</view>