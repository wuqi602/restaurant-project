.page-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading, .empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}

.detail-img {
  width: 100%;
  height: 600rpx;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-img image {
  width: 100%;
  height: 100%;
}
.img-placeholder {
  font-size: 120rpx;
  color: #ccc;
}

.detail-body {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
  border-radius: 20rpx 20rpx 0 0;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
}

.detail-price {
  font-size: 44rpx;
  color: #FF4D2E;
  font-weight: bold;
  margin-top: 16rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
  line-height: 1.6;
}

.quantity-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
.quantity-section .label {
  font-size: 28rpx;
  color: #333;
}
.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #EE3E0E;
  color: #EE3E0E;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}
.qty-btn.disabled {
  border-color: #ccc;
  color: #ccc;
}
.qty-num {
  font-size: 32rpx;
  font-weight: bold;
  min-width: 50rpx;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  height: 100rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.bottom-bar view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
}
.btn-cart {
  background: #fff;
  color: #EE3E0E;
  border-top: 2rpx solid #eee;
}
.btn-buy {
  background: linear-gradient(135deg, #FF6A00, #EE3E0E);
  color: #fff;
}
